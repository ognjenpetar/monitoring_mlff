# Kopiraj u .env i popuni vrednosti
# Na Railway/Render/Fly.io postavi ove varijable u dashboard-u

MONITOR_URL=https://ot.sdn.rs/portali/
CHECK_INTERVAL_SEC=60

# Email (Gmail preporucen – koristiti App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tvoj.email@gmail.com
SMTP_PASSWORD=app_password_ovde
EMAIL_RECIPIENTS=primalac1@example.com,primalac2@example.com
NOTIFY_EMAIL=true

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBCCddEEFF...
TELEGRAM_CHAT_IDS=-100123456789,987654321
NOTIFY_TELEGRAM=true
